{
  "name": "ffprobe-metadata-wasm",
  "version": "0.2.3",
  "description": "FFprobe WASM for browser - video/audio metadata probe only, Worker mode, no SharedArrayBuffer required",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('public/dist',{recursive:true,force:true});\"",
    "build:lib": "tsc --emitDeclarationOnly && vite build",
    "build:wasm": "docker build -t ffprobe-metadata-wasm . && docker run --rm -v \"$(pwd)/dist:/out\" ffprobe-metadata-wasm cp /build/dist/ffprobe-metadata-wasm.js /build/dist/ffprobe-metadata-wasm.wasm /out/",
    "build": "npm run clean && npm run build:wasm && npm run build:lib",
    "dev": "vite",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ffprobe",
    "wasm",
    "webassembly",
    "video",
    "metadata",
    "browser",
    "emscripten"
  ],
  "author": "laev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Laev/ffprobe-metadata-wasm.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
